NODE_ENV=production
PORT=3000

# Local or hosted Postgres — match your OS user/db (create DB if needed).
DATABASE_URL=postgresql://YOUR_USER@localhost:5432/surge_activity_log
#
# Vitest uses DATABASE_URL too; unless you export one, defaults point at surge_activity_log_test
# (see tests/setup/env.ts — run migrations against that DB for integration auth tests).

# Local or hosted Redis (TLS: use rediss://).
REDIS_URL=redis://127.0.0.1:6379/0

# pino severity: fatal, error, warn, info, debug, trace, silent — omit to use NODE_ENV-driven defaults.
# LOG_LEVEL=info
#
# Readable dev logs: `npm run dev` forces NODE_ENV=development and wires pino-pretty (deployed `npm start` stays JSON).
# JSON in dev anyway: LOG_PRETTY=0 npm run dev

# Browser clients on other origins (two front-ends) — comma-separated absolute origins:
# CORS_ORIGINS=https://agents.example.com,https://admin.example.com
#
# SPA on those origins must use fetch Axios etc with credentials enabled so surge_refresh travels on `/auth/refresh` and `/auth/logout`.
# Auth — generate strong secrets (distinct); access TTL e.g. 15m; refresh TTL e.g. 7d
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
