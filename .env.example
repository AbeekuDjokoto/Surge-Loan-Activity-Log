NODE_ENV=production
PORT=3000

# Local or hosted Postgres — match your OS user/db (create DB if needed).
DATABASE_URL=postgresql://YOUR_USER@localhost:5432/surge_activity_log
#
# Vitest uses DATABASE_URL too; unless you export one, defaults point at surge_activity_log_test
# (see tests/setup/env.ts — run migrations against that DB for integration auth tests).

# Local or hosted Redis (TLS: use rediss://).
REDIS_URL=redis://127.0.0.1:6379/0

# pino severity: fatal, error, warn, info, debug, trace, silent — omit to use NODE_ENV-driven defaults.
# LOG_LEVEL=info
#
# Readable dev logs: `npm run dev` forces NODE_ENV=development and wires pino-pretty (deployed `npm start` stays JSON).
# JSON in dev anyway: LOG_PRETTY=0 npm run dev

# Browser clients on other origins (two front-ends) — comma-separated absolute origins:
# CORS_ORIGINS=https://agents.example.com,https://admin.example.com
#
# SPA on those origins must use fetch Axios etc with credentials enabled so surge_refresh travels on `/auth/refresh` and `/auth/logout`.
# Auth — generate strong secrets (distinct); access TTL e.g. 15m; refresh TTL e.g. 7d
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Admin invite — SPA route without query string; `?token=` appended (like password reset).
# ADMIN_INVITE_URL_BASE=https://your-admin-spa.example.com/accept-admin-invite
# ADMIN_INVITE_TOKEN_TTL_HOURS=72

# Password reset — EMAIL_MODE=console logs reset links (no SMTP). Use smtp in production.
# EMAIL_MODE=console
# PASSWORD_RESET_URL_BASE=https://your-spa.example.com/reset-password
# PASSWORD_RESET_TOKEN_TTL_HOURS=1
#
# When EMAIL_MODE=smtp:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="Surge Activity Log <noreply@example.com>"

# One-time bootstrap after migrate — idempotent; assigns **admin-only** roles for SEED_ADMIN_EMAIL (strips user role).
# Password must be at least 12 characters (same as registration).
# SEED_ADMIN_EMAIL=admin@localhost.localdomain
# SEED_ADMIN_PASSWORD=change-me-twelve-char
# SEED_ADMIN_FULL_NAME=Seed Admin
# SEED_ADMIN_LOCATION=HQ
#
# Render (or similar) — build runs first; **`tsx`** is omitted from prod installs so DB scripts use **`dist/`**.
# · Build Command: **`npm run build`**
# · Start Command (migrations each deploy): **`npm run start:with-migrations`**
# · Seed on boot only after setting **`SEED_ADMIN_*`**: **`npm run start:with-migrations-and-seed`**
